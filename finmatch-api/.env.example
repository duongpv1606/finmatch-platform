# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=finmatch

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string

# ── AI provider: openai | anthropic | gemini ──
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Payments (optional — membership upgrade won't work without these, but
#    everything else runs fine) ──
# Stripe: get test keys free at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# VNPay: register a free sandbox merchant at https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
FRONTEND_URL=https://finmatch-platform.vercel.app
API_PUBLIC_URL=https://finmatch-platform-production.up.railway.app/api

# ── App ──
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
